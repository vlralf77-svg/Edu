# ====== AdMob Production IDs ======
# 프로덕션 빌드에서만 사용. 개발 중에는 테스트 광고 ID가 자동 적용됩니다.
# Google AdMob 콘솔에서 발급받은 실제 ID로 교체하세요.

# 앱 ID (AndroidManifest.xml / Info.plist 에도 동일하게 등록 필요)
VITE_ADMOB_APP_ID_ANDROID=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX
VITE_ADMOB_APP_ID_IOS=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX

# 배너 광고 단위 ID
VITE_ADMOB_BANNER_ANDROID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
VITE_ADMOB_BANNER_IOS=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX

# 보상형 광고 단위 ID
VITE_ADMOB_REWARDED_ANDROID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
VITE_ADMOB_REWARDED_IOS=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
